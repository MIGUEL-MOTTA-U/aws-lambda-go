DATABASE_CONNECTION=postgresql://postgres:postgres@localhost:5432/postgres?sslmode=disable

# Cloudflare R2 — credentials from Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=mi-app-assets
R2_ACCESS_KEY_ID=<r2-api-token-key-id>
R2_SECRET_ACCESS_KEY=<r2-api-token-secret>
R2_PUBLIC_URL=https://assets.tudominio.com


# Stage 1 only (pre-Cognito): allow uploads without a JWT authorizer.
# MUST be removed/false once Cognito is enabled (Stage 2).
ALLOW_UNAUTHENTICATED_UPLOADS=true

# Local dev server (used when running outside AWS Lambda via `go run .`)
PORT=8080
ACCESS_CONTROL_ALLOW_ORIGIN=http://localhost:5173

AUTH_CLIENT_ID=<client_id>
AUTH_CLIENT_SECRET=<client_secret>
REDIRECT_URL=<redirection_url>
USSUER_URL=<issuer_url>